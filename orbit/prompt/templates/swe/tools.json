              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "workdir": {
            "type": "string",
            "description": "Working directory for the command.",
            "default": "/app"
          }
        },
        "required": [
          "command"
        ]
      }
    }
  }
]
