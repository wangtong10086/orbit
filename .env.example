# === AWS DynamoDB ===
# 机器已通过 IAM 授权，不需要 access key
AWS_REGION=us-east-1
DYNAMODB_TABLE_PREFIX=affine

# Affine API (排行榜查询，无需认证)
API_URL=https://api.affine.io/api/v1

# HuggingFace (模型上传和checkpoint备份)
HF_TOKEN=
HF_DATASET_REPO=waston10086/test_data
HF_BACKUP_REPO=

# Chutes (模型部署推理)
CHUTES_API_KEY=

# Targon (GPU云，租用/管理远程训练机器)
TARGON_API_KEY=

# === 可选 ===
MY_HOTKEY=
MY_UID=
AMAP_API_KEY=
WANDB_API_KEY=
